[run]
source = src/pyaermod
omit =
    src/pyaermod/gui.py
    */__main__.py

[report]
show_missing = true
precision = 1
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__
    raise NotImplementedError
    pass
    if HAS_
    except ImportError

[html]
directory = htmlcov
